{
  "extends": [
    "group:aws-java-sdkMonorepo",
    "group:aws-java-sdk-v2Monorepo",
    "group:springBoot",
    "group:springCloud",
    "group:junit5Monorepo",
    "group:kotlinMonorepo",
    "group:mockitoMonorepo"
  ],
  "packageRules": [
    {
      "description": "HIGH: jackson-core - CVE-2025-52999",
      "matchPackageNames": ["com.fasterxml.jackson.core:jackson-core"],
      "matchManagers": ["maven", "gradle"],
      "vulnerabilitySeverity": ["HIGH"],
      "enabled": true,
      "automerge": false,
      "labels": ["security-high", "pkg:maven"],
      "prPriority": 8,
      "matchCurrentVersion": "<2.15.0",
      "minimumReleaseAge": "3 days",
      "semanticCommitType": "fix"
    },
    {
      "description": "HIGH: jackson-databind - CVE-2021-46877, CVE-2022-42003, CVE-2022-42004",
      "matchPackageNames": ["com.fasterxml.jackson.core:jackson-databind"],
      "matchManagers": ["maven", "gradle"],
      "vulnerabilitySeverity": ["HIGH"],
      "enabled": true,
      "automerge": false,
      "labels": ["security-high", "pkg:maven"],
      "prPriority": 8,
      "matchCurrentVersion": "<2.12.7.1",
      "minimumReleaseAge": "3 days",
      "semanticCommitType": "fix"
    },
    {
      "description": "HIGH: logback - CVE-2023-6378",
