    {
      "description": "Go CLI tools - automerge minor/patch",
      "matchPackageNames": [
        "terraform-docs/terraform-docs",
        "mikefarah/yq",
        "mvdan/sh",
        "docker/compose",
        "kubernetes-sigs/kustomize"
      ],
      "matchManagers": ["regex"],
      "matchUpdateTypes": ["minor", "patch"],
      "schedule": ["before 3am on Monday"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "prPriority": 7,
      "labels": ["dependencies", "go-tools", "automerge"],
      "semanticCommitType": "fix"
    },
    {
      "description": "kubectl - cluster compatibility required",
      "matchPackageNames": ["kubernetes/kubernetes"],
      "matchManagers": ["regex"],
      "schedule": ["before 3am on Monday"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "prPriority": 9,
      "labels": ["dependencies", "kubectl", "cluster-compatibility"],
      "prBodyNotes": [
        "⚠️ **Cluster Compatibility Check Required**",
        "",
        "kubectl must be within ±1 minor version of your Kubernetes cluster.",
        "Verify cluster version before merging: `kubectl version`"
      ],
      "semanticCommitType": "fix"
    },
    {
      "description": "GitHub CLI",
      "matchPackageNames": ["cli/cli"],
      "matchManagers": ["regex"],
      "schedule": ["before 3am on Monday"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "prPriority": 6,
      "labels": ["dependencies", "github-cli"],
      "semanticCommitType": "fix"
    },
    {
      "description": "golangci-lint - breaking change risk",
      "matchPackageNames": ["golangci/golangci-lint"],
      "matchManagers": ["regex"],
      "schedule": ["before 3am on Monday"],
      "minimumReleaseAge": "14 days",
      "automerge": false,
      "prPriority": 5,
      "labels": ["dependencies", "breaking-change-risk"],
      "prBodyNotes": [
        "⚠️ **Breaking Change Risk**",
        "",
        "Large version jumps may introduce new linting rules.",
        "Test in non-prod first. Teams can disable rules in `.golangci.yml`."
      ],
      "semanticCommitType": "fix"
    },
    {
      "description": "pre-commit - updates binary only, not cache",
      "matchPackageNames": ["pre-commit"],
      "matchManagers": ["regex", "pip_requirements"],
      "schedule": ["before 3am on Monday"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "prPriority": 6,
      "labels": ["dependencies", "pre-commit"],
      "prBodyNotes": [
        "📝 **Note:** This updates the pre-commit binary only.",
        "",
        "Cached hook dependencies are not updated automatically.",
        "To update cache, add: `RUN pre-commit clean` before `pre-commit install-hooks`"
      ],
      "semanticCommitType": "fix"
    },
    {
      "description": "Python system package security upgrades (installed via pip after apt)",
      "matchPackageNames": [
        "cryptography",
        "setuptools",
        "pyyaml",
        "pip",
        "wheel",
        "oauthlib"
      ],
      "matchManagers": ["regex", "pip_requirements"],
      "matchFiles": ["**/Dockerfile", "**/Dockerfile.*"],
      "groupName": "Python System Security Packages",
      "schedule": ["before 3am on Monday"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "prPriority": 8,
      "labels": ["security", "python-system", "dockerfile"],
      "semanticCommitType": "fix"
    }
  ],
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Docker image updates and container security patches (pip packages from Wiz analysis + Go binary tools)",
  "customManagers": [
    {
      "description": "terraform-docs version",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": [
        "ARG TERRAFORM_DOCS_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "terraform-docs/terraform-docs",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "description": "yq version",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": ["ARG YQ_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mikefarah/yq"
    },
    {
      "description": "kubectl version",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": [
        "ARG KUBECTL_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes/kubernetes",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "description": "docker-compose version",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": [
        "ARG DOCKER_COMPOSE_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "docker/compose"
    },
    {
      "description": "GitHub CLI version",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": ["ARG GH_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "cli/cli"
    },
    {
      "description": "golangci-lint version",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": [
        "ARG GOLANGCI_LINT_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "golangci/golangci-lint"
    },
    {
      "description": "shfmt version",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": [
        "ARG SHFMT_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mvdan/sh"
    },
    {
      "description": "kustomize version",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": [
        "ARG KUSTOMIZE_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes-sigs/kustomize"
    },
    {
      "description": "Detect pip install versions in Dockerfiles",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\.[^/]*$"],
      "matchStrings": [
        "pip install.*?(?<depName>[a-zA-Z0-9_-]+)>=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "pypi"
    }
  ]
}
