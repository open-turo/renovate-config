{
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "semanticCommitType": "fix"
    },
    {
      "description": "Dockerfile base images - automerge patch/minor for security",
      "matchDatasources": ["docker"],
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "vulnerabilitySeverity": ["CRITICAL", "HIGH"],
      "prPriority": 10,
      "automerge": true,
      "platformAutomerge": true,
      "minimumReleaseAge": "0 days",
      "labels": ["security", "dockerfile", "automerge"],
      "groupName": "Dockerfile Security Updates",
      "schedule": ["at any time"]
    },
    {
      "description": "ARG-based version pins in Dockerfiles - kubectl, kustomize, yq, terraform-docs, etc.",
      "matchManagers": ["dockerfile"],
      "matchFileNames": ["**/Dockerfile", "**/Dockerfile.*"],
      "vulnerabilitySeverity": ["CRITICAL", "HIGH"],
      "prPriority": 9,
      "labels": ["security", "dockerfile-args"],
      "groupName": "Dockerfile ARG Security Updates"
    },
    {
      "description": "apt packages in Dockerfiles",
      "matchManagers": ["dockerfile"],
      "matchDepTypes": ["final"],
      "prPriority": 8,
      "labels": ["security", "apt-packages"]
    },
    {
      "description": "CRITICAL: pillow",
      "matchPackageNames": ["pillow"],
      "matchManagers": ["pip_requirements", "regex"],
      "matchFiles": ["**/Dockerfile", "**/Dockerfile.*"],
      "enabled": true,
      "automerge": true,
      "labels": ["security-critical", "pkg:pip"],
      "prPriority": 10,
      "matchCurrentVersion": "<10.0.0",
      "semanticCommitType": "fix"
    },
    {
